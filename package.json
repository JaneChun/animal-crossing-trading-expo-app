{
  "name": "animal-crossing-trading-app",
  "main": "node_modules/expo/AppEntry.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "dev:emulator": "EXPO_PUBLIC_USE_FIREBASE_EMULATOR=true expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "cd functions && tsc --noEmit",
    "test:functions": "npm test --prefix functions",
    "test:e2e": "jest --selectProjects maestro --runInBand",
    "build:ios": "eas build --profile production --platform ios",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:android": "eas build --profile production --platform android",
    "build:android:dev": "eas build --profile development --platform android",
    "deploy:app": "eas submit -p ios --latest",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules:firestore": "firebase deploy --only firestore:rules",
    "deploy:rules:storage": "firebase deploy --only storage",
    "emulator:start": "firebase emulators:start",
    "emulator:start-with-data": "firebase emulators:start --import ./emulator-data --export-on-exit",
    "emulator:stop": "pkill -f 'firebase emulators' || true && lsof -ti:4000,4400,4401,4500,4501,8080,9099,5001,9199 | xargs kill -9 2>/dev/null || true && echo 'Firebase emulators stopped'",
    "emulator:seed": "node scripts/seed-test-data.js",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --fix"
  },
  "dependencies": {
    "@expo/react-native-action-sheet": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.0.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-firebase/analytics": "^23.8.4",
    "@react-native-firebase/app": "^23.8.4",
    "@react-native-kakao/core": "^2.2.6",
    "@react-native-kakao/user": "^2.2.6",
    "@react-native-seoul/naver-login": "^4.2.4",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/material-top-tabs": "^7.2.2",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@tanstack/react-query": "^5.90.5",
    "algoliasearch": "^5.27.0",
    "axios": "^1.7.9",
    "cenkor": "^1.0.0",
    "expo": "^54.0.36",
    "expo-apple-authentication": "~8.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-checkbox": "~5.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-web-browser": "~15.0.11",
    "firebase": "^10.14.1",
    "immer": "^10.1.1",
    "lodash": "^4.17.21",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.56.1",
    "react-native": "0.81.5",
    "react-native-awesome-gallery": "^0.4.3",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-gifted-chat": "^2.8.1",
    "react-native-google-mobile-ads": "^16.4.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-pager-view": "6.9.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-snap-carousel": "^3.9.1",
    "react-native-tab-view": "^4.0.6",
    "react-native-toast-message": "^2.2.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.24.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@react-native-community/cli": "^20.0.2",
    "@tanstack/eslint-plugin-query": "^5.72.1",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.16",
    "@types/react": "~19.1.0",
    "@types/react-native-snap-carousel": "^3.8.12",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "firebase-admin": "^13.6.0",
    "firebase-tools": "^15.1.0",
    "husky": "^9.1.7",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.0",
    "lint-staged": "^16.3.2",
    "react-test-renderer": "^19.1.0",
    "reactotron-react-native": "^5.1.18",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "query-string": "6.14.1"
  }
}
